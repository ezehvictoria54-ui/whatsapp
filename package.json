{
  "name": "whatsapp-lead-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Automated WhatsApp lead pipeline on the official Cloud API: capture -> instant reply -> 7-day follow-up -> auto-remove on payment.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "seed": "DRY_RUN=true node dist/db/seed.js",
    "seed:dev": "DRY_RUN=true tsx src/db/seed.ts",
    "worker": "node dist/worker/standalone.js",
    "worker:dev": "tsx src/worker/standalone.ts",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "DRY_RUN=true DATABASE_URL=postgres://localhost:5432/test tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/static": "^7.0.4",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2"
  }
}
