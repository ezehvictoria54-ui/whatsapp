# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=            # permanent system-user token (NOT the 24h temp token)
WA_APP_SECRET=             # used to verify X-Hub-Signature-256 on inbound webhooks
WA_VERIFY_TOKEN=           # your chosen webhook verify token (GET verification)
WA_BUSINESS_ACCOUNT_ID=
WA_GRAPH_VERSION=v21.0

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whatsapp_lead_engine

# ─── Optional AI replies (Claude) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_REPLIES_ENABLED=false
AI_SYSTEM_PROMPT=You are a friendly sales assistant. Qualify the lead and answer briefly with one clear call to action.

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
DAILY_SEND_CAP=250         # start low; the warm-up ramp raises the effective cap over time
WARMUP_START_DATE=         # ISO date the number started warming up; blank = today. Drives the ramp.
SEND_RATE_PER_SEC=10       # max outbound follow-up sends per worker tick burst
BUSINESS_NAME=Our Store
DELIVERY_DETAILS=We will send your product/next steps shortly.
DEFAULT_OFFER_PRICE_KOBO=500000   # price (kobo) for the auto-created default offer; existing single-offer leads use this

# Set to "true" to skip real HTTP calls to Meta/Paystack (useful for local/dev/testing)
DRY_RUN=false

# Set to "true" to insert ~10 demo leads on startup (idempotent). Handy for
# populating the dashboard from the Railway UI — turn it on, let it deploy, then
# turn it back off. Leave false in normal operation.
SEED_ON_BOOT=false
